# VIBE.TESTING Runner — Environment Configuration
# Copy this file to .env and fill in your values

# ── SMTP Email (for sending reports) ──
# For Gmail: use an App Password (not your regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── Anthropic API Key (for script generation) ──
# If set, the runner will use Claude to generate real test scripts
# If not set, realistic mock results will be generated from your STD
ANTHROPIC_API_KEY=sk-ant-api03-...
